{
  "compilerOptions": {
    "baseUrl": ".",
    "declaration": true,
    "emitDeclarationOnly": false,
    "ignoreDeprecations": "6.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "asljs-components": [
        "components/src/index.ts"
      ],
      "asljs-dali": [
        "dali/src/index.ts"
      ],
      "asljs-data-binding": [
        "data-binding/src/index.ts"
      ],
      "asljs-eventful": [
        "eventful/src/index.ts"
      ],
      "asljs-machine": [
        "machine/src/index.ts"
      ],
      "asljs-money": [
        "money/src/index.ts"
      ],
      "asljs-observable": [
        "observable/src/index.ts"
      ]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020"
  }
}
