{
  "name": "asljs-cog",
  "version": "0.1.2",
  "description": "Context building library and CLI for AI agents using envelope and patch workflows.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**",
    "bin/**",
    "README.md",
    "LICENSE.md"
  ],
  "bin": {
    "cog": "bin/cog.js"
  },
  "scripts": {
    "clean": "node -e \"console.log('asljs-cog: nothing to clean')\"",
    "build": "npx tsc -p tsconfig.build.json",
    "build:dist": "npx tsc -p tsconfig.dist.json",
    "typecheck": "npx tsc -p tsconfig.build.json --noEmit",
    "lint": "",
    "lint:fix": "",
    "guard:clean-git": "node ../toolkit.js ensure-clean-working-folder",
    "prepublishOnly": "npm run build",
    "postpublish": "node ../toolkit.js tag-commit-with-release-id",
    "test": "npm run build && node --test build/**/*.test.js",
    "test:watch": "npm run build && node --watch --test build/**/*.test.js",
    "release:patch": "node ../toolkit.js release-patch"
  },
  "keywords": [
    "ai",
    "agents",
    "context",
    "envelope",
    "patch",
    "cli"
  ],
  "homepage": "https://github.com/AlexandriteSoftware/asljs#readme",
  "bugs": {
    "url": "https://github.com/AlexandriteSoftware/asljs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandriteSoftware/asljs.git"
  },
  "author": "\"Alex Netkachov\" <alex.netkachov@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
