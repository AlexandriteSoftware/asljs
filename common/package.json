{
  "name": "asljs-common",
  "version": "0.1.0",
  "description": "Common packages and scripts for ASLJS projects.",
  "type": "module",
  "scripts": {
    "format:json": "dprint fmt --config ../dprint.json \"*.json\"",
    "format": "npm run format:json",
    "clean": "node ./dist/toolkit/toolkit.js clean",
    "build": "tsc -p tsconfig.build.json",
    "build:dist": "tsc -p tsconfig.dist.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test --enable-source-maps build/**/*.test.js",
    "all": "npm run build:dist && npm run clean && npm run build:dist && npm run format && npm run typecheck && npm run lint && npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "acorn": "^8.17.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
