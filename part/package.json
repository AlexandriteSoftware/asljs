{
  "name": "asljs-part",
  "version": "0.1.25",
  "description": "Project artefact tracing framework and CLI for markdown-defined project artefacts.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "artefacts/parts/Artefact Definition_RL1.js",
    "artefacts/parts/Artefact Definition.js",
    "artefacts/parts/Article_RL1.js",
    "artefacts/parts/Article_RL2.js",
    "artefacts/parts/Rule File_RL1.js",
    "artefacts/Artefact Definition.md",
    "artefacts/Article.md",
    "artefacts/Rule File.md",
    "bin/**",
    "src/**",
    "README.md",
    "LICENSE.md",
    "DEVELOPMENT.md"
  ],
  "bin": {
    "part": "bin/part.js"
  },
  "scripts": {
    "clean": "node -e \"console.log('asljs-part: nothing to clean')\"",
    "build": "node -e \"console.log('asljs-part: no build step for JS source package')\"",
    "typecheck": "npx tsc -p tsconfig.json --noEmit",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "guard:clean-git": "node ../toolkit.js ensure-clean-working-folder",
    "postpublish": "node ../toolkit.js tag-commit-with-release-id",
    "test": "node --test",
    "test:watch": "node --watch --test",
    "coverage": "NODE_V8_COVERAGE=.coverage node --test && node -e \"console.log('Coverage in .coverage (use c8/istanbul if you want reports)')\"",
    "release:patch": "node ../toolkit.js release-patch"
  },
  "keywords": [
    "traceability",
    "artefacts",
    "requirements",
    "markdown",
    "cli"
  ],
  "homepage": "https://github.com/AlexandriteSoftware/asljs#readme",
  "bugs": {
    "url": "https://github.com/AlexandriteSoftware/asljs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandriteSoftware/asljs.git"
  },
  "author": "\"Alex Netkachov\" <alex.netkachov@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "remark-parse": "^11.0.0",
    "typescript-eslint": "^8.61.1",
    "unified": "^11.0.5"
  }
}
