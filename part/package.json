{
  "name": "asljs-part",
  "version": "0.1.31",
  "description": "Project artefact tracing framework and CLI for markdown-defined project artefacts.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "artefacts/parts/Artefact Definition_RL1.js",
    "artefacts/parts/Artefact Definition.js",
    "artefacts/parts/Article_RL1.js",
    "artefacts/parts/Article_RL2.js",
    "artefacts/parts/Rule File_RL1.js",
    "artefacts/Artefact Definition.md",
    "artefacts/Article.md",
    "artefacts/Rule File.md",
    "bin/**",
    "src/**",
    "README.md",
    "LICENSE.md",
    "DEVELOPMENT.md"
  ],
  "bin": {
    "part": "bin/part.js"
  },
  "scripts": {
    "format:json": "prettier --write --no-error-on-unmatched-pattern \"*.json\"",
    "format": "npm run format:json",
    "clean": "node ../common/dist/toolkit/toolkit.js clean",
    "build": "tsc -p tsconfig.build.json",
    "build:dist": "tsc -p tsconfig.dist.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "guard:clean-git": "node ../common/dist/toolkit/toolkit.js ensure-clean-working-directory",
    "prepack": "npm run clean && npm run build && npm run test && npm run build:dist && npm run guard:clean-git",
    "postpublish": "node ../common/dist/toolkit/toolkit.js tag-release-revision",
    "test": "node --test --enable-source-maps build/**/*.test.js artefacts/**/*.test.js",
    "test:watch": "node --watch --test build/**/*.test.js",
    "release:patch": "node ../common/dist/toolkit/toolkit.js release-patch",
    "all": "npm run clean && npm run format && npm run typecheck && npm run lint && npm run build:dist && npm run build && npm run test"
  },
  "keywords": [
    "traceability",
    "artefacts",
    "requirements",
    "markdown",
    "cli"
  ],
  "homepage": "https://github.com/AlexandriteSoftware/asljs#readme",
  "bugs": {
    "url": "https://github.com/AlexandriteSoftware/asljs/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandriteSoftware/asljs.git"
  },
  "author": "\"Alex Netkachov\" <alex.netkachov@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "glob": "^13.0.6",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "remark-parse": "^11.0.0",
    "typescript-eslint": "^8.63.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "asljs-tmpdir": "^0.1.9",
    "eslint": "^10.6.0"
  }
}
