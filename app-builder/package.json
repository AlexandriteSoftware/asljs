{
  "name": "asljs-app-builder",
  "version": "0.1.0",
  "description": "Browser-based AI-assisted local-first app builder — GitHub Pages front page and demo for ASLJS.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "asljs-components": "^0.1.3",
    "asljs-dali": "^0.1.3",
    "asljs-data-binding": "^0.2.4",
    "asljs-eventful": "^0.4.9",
    "asljs-observable": "^0.5.4",
    "esbuild": "^0.27.0",
    "esbuild-wasm": "^0.27.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.6",
    "vite": "^6.4.2"
  }
}
